{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "esModuleInterop": true,
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"],
    "outDir": "dist"
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
